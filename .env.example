# =============================================================================
# Doris 数据库配置
# =============================================================================
DORIS_HOST=doris
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=
DORIS_DATABASE=opsRobot

# =============================================================================
# API 服务配置
# =============================================================================
PORT=8787

# =============================================================================
# 前端配置（Docker 环境中 API 地址）
# =============================================================================
VITE_API_URL=/api

# 时区设置
TIMEZONE=Asia/Shanghai
# =============================================================================
# 前端 Mock 模式（无需数据库，用于 UI 调试）
# 启用方式：npm run dev:mock 或设置下方变量为 true 后运行 npm run dev
# =============================================================================
# VITE_MOCK=true

# =============================================================================
# 数据目录 / 分组（后端）
# =============================================================================
# 仅当为 true 时，数据源分组 API 使用内存 mock，不写 Doris（catalog_groups 等表）。
# 默认不写或 false：分组持久化到 Doris。与 VITE_MOCK 无关。
# CATALOG_GROUPS_MOCK=true

# 仅当为 true 时，catalog_registry 走内存 mock，不写 Doris。与分组开关独立。
# CATALOG_REGISTRY_MOCK=true

# 默认 true：数据源创建仅支持 Doris 原生 Catalog（CREATE CATALOG / SHOW CATALOGS）。
# 若设置为 false，系统将拒绝创建数据源（不再提供旧版/降级创建路径）。
# DORIS_NATIVE_CATALOG=true

# 数据视图走内存 mock（内置 5 条示例，含 192.168.64.239 跨源），不写 Doris。可取 true / 1 / yes / on。
# 若已设置 VITE_MOCK=true，无需再写本项也会启用数据视图 Mock。
# VIEW_REGISTRY_MOCK=true
